{
  "manifest_version": 3,
  "name": "Manga Chapter Tracker",
  "version": "0.1.2",
  "description": "Track which chapter you're on across manga sites. One library for every series you read.",
  "permissions": ["storage", "activeTab", "unlimitedStorage"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Manga Chapter Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
