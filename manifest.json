{
    "manifest_version": 3,
    "name": "Shiori",
    "version": "0.3.2",
    "description": "Never lose your place. Shiori tracks the chapter you're on across manga sites, in one library.",
    "key": "",
    "permissions": ["storage", "activeTab", "unlimitedStorage", "identity"],
    "host_permissions": ["https://fohkznuvisjohcuzelca.supabase.co/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Shiori",
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    }
}
